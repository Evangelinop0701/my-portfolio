<%- include("../../admin/header") %>
<%- include("../../admin/nav") %>
<section id="projects" class="py-5">
    <div class="container mt-3">
        <div class="card mb-5">
            <div class="card-header">
                <div class="card-title">
                    <h3><%= title %></h3>
                </div>
            </div>
            <div class="card-body">
                <div class="my-2">
                    <a href="/skills/form" class="btn btn-success btn-sm rounded-1"><i class="fas fa-plus"></i> Add
                        Skills</a>
                    <a href="/api/skills" class="btn btn-success btn-sm rounded-1">GET API Skills</a>
                </div>
                <table id="projectsTable" class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th class="py-1">No</th>
                            <th class="py-1">Skill</th>
                            <th class="py-1">Kategoria</th>
                            <th class="py-1">Durasaun</th>
                            <th class="py-1">#</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.forEach((data, index) => { %>
                        <tr>
                            <td class="py-1"><%= index + 1 %></td>
                            <td class="py-1"><%= data.skill_name %></td>
                            <td class="py-1"><%= data.ktg %></td>
                            <td class="py-1"><%= data.durasaun %></td>
                            <td class="py-1">
                                <a href="/skills/edit/<%= data.id %>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/skills/delete/<%= data.id %>" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<%- include("../../admin/footer") %>